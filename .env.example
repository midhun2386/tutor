# HuggingFace API Token (required for LLM downloads)
HF_TOKEN=your_huggingface_token_here

# Whisper model to use: tiny, base, small, medium, large
WHISPER_MODEL=small

# Emotion model checkpoint from HuggingFace Hub
EMOTION_MODEL=ehcalabres/wav2vec2-lg-xlsr-en-speech-emotion-recognition

# LLM model checkpoint (High quality Llama 3.2 model)
LLM_MODEL=meta-llama/Llama-3.2-1B-Instruct

# Default language for vernacular content: tamil, hindi, english
DEFAULT_LANGUAGE=tamil

# FastAPI backend URL (used by Streamlit)
API_BASE_URL=http://localhost:8000

# SQLite database location
DATABASE_URL=sqlite:///./tutor.db

# Set to 1 to use mock models (no GPU / token needed for development)
USE_MOCK_MODELS=0
